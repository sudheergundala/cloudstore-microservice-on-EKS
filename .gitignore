# Dependencies (huge folders, regenerated by install commands)
node_modules/
vendor/
__pycache__/
*.pyc
.venv/

# Environment files with secrets
.env
.env.local
.env.production

# Build outputs (regenerated by build commands)
dist/
build/
bin/

# IDE and OS files
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Logs
*.log

# Test coverage
coverage/
htmlcov/

# ── Terraform ──
# State files (contain secrets in plaintext — NEVER commit)
*.tfstate
*.tfstate.*
# Working directory (downloaded providers/modules — large, machine-specific)
.terraform/
# Crash logs
crash.log
crash.*.log
# Plan output files (may contain secrets)
*.tfplan
# Variable files that may contain secrets
*.tfvars
!*.example.tfvars
